  command = $PRE_LINK && /home/rehan-10xe/Downloads/riscv64-glibc-ubuntu-22.04-gcc/riscv/bin/riscv64-unknown-linux-gnu-g++ --sysroot=/home/rehan-10xe/Downloads/riscv64-glibc-ubuntu-22.04-gcc/riscv/sysroot $FLAGS $LINK_FLAGS $in -o $TARGET_FILE $LINK_PATH $LINK_LIBRARIES && $POST_BUILD
  description = Linking CXX executable $TARGET_FILE
  restat = $RESTAT


